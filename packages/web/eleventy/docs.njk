---
layout: base.njk
pagination:
  data: docs
  size: 1
  alias: doc
permalink: "/docs/{{ doc.slug }}.html"
eleventyComputed:
  title: "{{ doc.title }} — typeDiagram"
  description: "{{ doc.title }} — typeDiagram documentation. Language-neutral DSL for describing algebraic data types and generating code in TypeScript, Python, Rust, Go, and C#."
  structuredData:
    "@context": "https://schema.org"
    "@type": "TechArticle"
    headline: "{{ doc.title }}"
    description: "{{ doc.title }} — typeDiagram documentation."
    url: "https://typediagram.dev/docs/{{ doc.slug }}.html"
    inLanguage: "en"
stylesHref: /src/styles.css
navLogoLink: /
navPlaygroundHref: /#playground
navConverterHref: /converter.html
navDocsHref: /docs/
navBlogHref: /blog/
---
<div class="docs-layout">
  <aside class="docs-sidebar">
    <ul class="docs-nav">
      {% for d in docs %}
        {% if "api/" not in d.slug %}
          <li><a href="/docs/{{ d.slug }}.html" class="{% if d.slug == doc.slug %}active{% endif %}">{{ d.label }}</a></li>
        {% endif %}
      {% endfor %}
    </ul>
    <h4>API Reference</h4>
    <ul class="docs-nav">
      {% for d in docs %}
        {% if "api/" in d.slug and d.isTopLevel %}
          <li><a href="/docs/{{ d.slug }}.html" class="{% if d.slug == doc.slug %}active{% endif %}">{{ d.label }}</a></li>
        {% endif %}
      {% endfor %}
    </ul>
  </aside>
  <main class="docs-content">{{ doc.html | safe }}</main>
</div>
