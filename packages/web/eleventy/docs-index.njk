      {% for d in docs %}
        {% if "api/" in d.slug and d.isTopLevel %}
          <li><a href="/docs/{{ d.slug }}.html">{{ d.label }}</a></li>
        {% endif %}
      {% endfor %}
    </ul>
  </aside>
  <main class="docs-content">{{ active.html | safe }}</main>
